<Window x:Class="WarehouseInventory.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WarehouseInventory.Windows"
        xmlns:viewModels="clr-namespace:WarehouseInventory.ViewModels"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="800" Width="800">
    
    <Window.DataContext>
        <viewModels:RegisterViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="30"
                          ShadowDepth="5"
                          Opacity="0.15"/>
        
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                CornerRadius="12"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Background="White">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#edede9"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd"
                                CornerRadius="12"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Background="White">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#edede9"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <!-- я думал, тут avalonia. А это wpf. Только менять оформление целиком
            пример: https://msdn-whiteknight.github.io/dotnet-docs-ru/html/framework/wpf/controls/combobox-styles-and-templates.html -->
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="White"
            CornerRadius="26"
            Margin="20"
            Effect="{StaticResource CardShadow}">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="30">

                <Border Width="70"
                        Height="70"
                        CornerRadius="35"
                        Background="#ECFDF5"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <TextBlock Text="📝"
                               FontSize="34"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                
                <TextBlock Text="Регистрация"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Создайте новый аккаунт"
                           FontSize="13"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,25"/>
                
                <TextBlock Text="Фамилия" Margin="0,0,0,6"/>
                <TextBox Text="{Binding LastName}" Margin="0,0,0,14"/>
                
                <TextBlock Text="Имя" Margin="0,0,0,6"/>
                <TextBox Text="{Binding FirstName}" Margin="0,0,0,14"/>
                
                <TextBlock Text="Логин" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Login}" Margin="0,0,0,14"/>
                
                <TextBlock Text="Пароль" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,14"/>
                
                <TextBlock Text="Подтвердите пароль" Margin="0,0,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,18"/>
                
                <TextBlock Text="Роль" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding Roles}"
                          SelectedItem="{Binding SelectedRole}"
                          DisplayMemberPath="Role"
                          Margin="0,0,0,25"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Content="◀ Назад"
                            Width="130"
                            Margin="0,0,10,0"
                            Background="White"
                            Command="{Binding GoBackCommand}"/>

                    <Button Content="✅ Зарегистрироваться"
                            Width="180"
                            Background="#10B981"
                            Foreground="White"
                            Command="{Binding RegisterCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>

</Window>
