<Window x:Class="WarehouseInventory.Windows.InvoicesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WarehouseInventory.Windows"
        mc:Ignorable="d"
        Title="InvoicesWindow" Height="720"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">
    
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          BlurRadius="18"
                          ShadowDepth="4"
                          Opacity="0.08"/>
        
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Content="☰"
                    FontSize="30"
                    Width="42"
                    Height="42"
                    Background="#F4F6F9"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    Command="{Binding ToggleMenuCommand}"
                    />

            
            <Popup IsOpen="{Binding IsMenuOpen}"
                   PlacementTarget="{Binding ElementName=MenuButton}"
                   Placement="Bottom"
                   StaysOpen="False">

                <Border Background="White"
                        Width="220"
                        CornerRadius="12"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="8"
                        Effect="{StaticResource CardShadow}">

                    <StackPanel>

                        <TextBlock Text="📂 Навигация"
                                   FontWeight="SemiBold"
                                   Margin="8,5,8,10"/>

                        <Separator/>

                        <Button Content="🏠 Дашборд"
                                Style="{StaticResource MenuButtonStyle}"
                                Command="{Binding NavigateDashboardCommand}"/>

                        <Button Content="📦 Товары"
                                Style="{StaticResource MenuButtonStyle}"
                                Command="{Binding NavigateProductsCommand}"/>

                        <Button Content="👤 Клиенты"
                                Style="{StaticResource MenuButtonStyle}"
                                Command="{Binding NavigateCustomersCommand}"/>

                        <Button Content="🏭 Поставщики"
                                Style="{StaticResource MenuButtonStyle}"
                                Command="{Binding NavigateSuppliersCommand}"/>

                        <Button Content="🧾 Накладные"
                                Style="{StaticResource MenuButtonStyle}"
                                IsEnabled="False"/>

                        <Button Content="📊 Движения"
                                Style="{StaticResource MenuButtonStyle}"
                                Command="{Binding NavigateMovementsCommand}"/>

                        <Button Content="📈 Отчёты"
                                Style="{StaticResource MenuButtonStyle}"
                                Command="{Binding NavigateReportsCommand}"/>

                        <Separator/>

                        <Button Content="🚪 Выход"
                                Style="{StaticResource MenuButtonStyle}"
                                Foreground="#EF4444"
                                Command="{Binding LogoutCommand}"/>

                    </StackPanel>
                </Border>
            </Popup>
            
            <TextBlock Grid.Column="1"
                       Text="🧾 Накладные"
                       FontSize="26"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
            
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                
                <Border Width="360"
                        Height="40"
                        Background="White"
                        CornerRadius="10"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Margin="0,0,10,0">
                    <Grid>
                        <TextBlock Text="🔍"
                                   FontSize="19"
                                   Foreground="#9CA3AF"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                        
                        <TextBox Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Margin="48,0,40,0"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <Button Content="✕"
                                Width="30"
                                Height="30"
                                FontSize="20"
                                HorizontalAlignment="Right"
                                Margin="0,0,8,0"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderBrush="Transparent"
                                Command="{Binding ClearSearchCommand}"/>
                    
                    </Grid>
                </Border>
                
                <Button Content="✚ Создать"
                        Width="150"
                        Height="40"
                        Background="#3B82F6"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Command="{Binding OpenCreateInvoiceCommand}"/>

            </StackPanel>
        </Grid>
        
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Padding="12"
                Effect="{StaticResource CardShadow}">

            <DataGrid ItemsSource="{Binding Invoices}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="48"
                      GridLinesVisibility="None"
                      AlternatingRowBackground="#F9FAFB">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="120"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="150"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="120"/>
                    <DataGridTextColumn Header="Контрагент" Binding="{Binding Counterparty}" Width="*"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount}" Width="150"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>
</Window>
