<Window x:Class="WarehouseInventory.Windows.MovementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WarehouseInventory.Windows"
        mc:Ignorable="d"
        Title="MovementsWindow" Height="450" Width="900">
    
    <Window.Resources>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          BlurRadius="20"
                          ShadowDepth="4"
                          Opacity="0.08"/>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    
    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
         
        <Grid Grid.Row="0" Margin="0,0,0,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Grid>

                <Button Content="☰"
                        Width="42"
                        Height="42"
                        FontSize="28"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        Command="{Binding ToggleMenuCommand}"/>

                <Popup IsOpen="{Binding IsMenuOpen}"
                       PlacementTarget="{Binding ElementName=MenuButton}"
                       Placement="Bottom"
                       StaysOpen="False">

                    <Border Background="White"
                            Width="220"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Padding="8"
                            Effect="{StaticResource CardShadow}">

                        <StackPanel>

                            <TextBlock Text="📂 Навигация"
                                       FontWeight="SemiBold"
                                       Margin="8,5,8,10"/>

                            <Separator/>

                            <Button Content="📊 Дашборд"
                                    Command="{Binding NavigateDashboardCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"/>

                            <Button Content="📦 Товары"
                                    Command="{Binding NavigateProductsCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"/>

                            <Button Content="🧾 Накладные"
                                    Command="{Binding NavigateInvoicesCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"/>

                            <Button Content="👤 Клиенты"
                                    Command="{Binding NavigateCustomersCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"/>

                            <Separator/>

                            <Button Content="🚪 Выход"
                                    Foreground="#EF4444"
                                    Command="{Binding LogoutCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
            
            <TextBlock Grid.Column="1"
                       Text="➡︎ Движение товаров"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
            
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                
                <Border Width="320"
                        Height="42"
                        Background="White"
                        CornerRadius="10"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Margin="0,0,15,0">

                    <Grid>
                        <TextBlock Text="🔍"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#9CA3AF"/>

                        <TextBox Margin="40,0,10,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
                
                <ComboBox Width="150"
                          Height="42"
                          Background="White"
                          BorderBrush="#D1D5DB"
                          BorderThickness="1"
                          SelectedItem="{Binding SelectedMovementType}"
                          ItemsSource="{Binding MovementTypes}"
                          ToolTip="Приход или расход"/>
            </StackPanel>
        </Grid>
        
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="10"
                Effect="{StaticResource CardShadow}">

            <DataGrid ItemsSource="{Binding Movements}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      RowHeight="52"
                      SelectionMode="Single">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="📅 Дата"
                                        Binding="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}"
                                        Width="170"/>

                    <DataGridTextColumn Header="📦 Товар"
                                        Binding="{Binding ProductName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="🔖 Тип"
                                        Binding="{Binding MovementType}"
                                        Width="120"/>

                    <DataGridTextColumn Header="🔗 Кол-во"
                                        Binding="{Binding Quantity}"
                                        Width="100"/>

                    <DataGridTextColumn Header="🧾 Накладная"
                                        Binding="{Binding InvoiceNumber}"
                                        Width="140"/>

                    <DataGridTextColumn Header="👤 Сотрудник"
                                        Binding="{Binding EmployeeName}"
                                        Width="160"/>

                </DataGrid.Columns>

            </DataGrid>
        </Border>

    </Grid>
</Window>
