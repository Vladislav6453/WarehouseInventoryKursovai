<Window x:Class="WarehouseInventory.Windows.EmployeesEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WarehouseInventory.Windows"
        mc:Ignorable="d"
        Title="EmployeesEditWindow" Height="620" Width="600">
    <Window.Resources>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          BlurRadius="20"
                          ShadowDepth="4"
                          Opacity="0.10"/>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Border Background="White"
                CornerRadius="18"
                Padding="24"
                Width="460"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="👤 Регистрация клиента"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,20"/>
                
                <StackPanel Grid.Row="1">
                    
                    <TextBlock Text="📄 Фамилия"
                               FontSize="12"
                               Foreground="#4B5563"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="📃 Имя"
                               FontSize="12"
                               Foreground="#4B5563"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="👑 Роль"
                               FontSize="12"
                               Foreground="#4B5563"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedRole}"
                              DisplayMemberPath="RoleName"
                              Margin="0,0,0,14"/>
                    
                    <TextBlock Text="🔑 Логин"
                               FontSize="12"
                               Foreground="#4B5563"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>
                    
                    <TextBlock Text="🔒 Пароль"
                               FontSize="12"
                               Foreground="#4B5563"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,0,0,14"
                                 PasswordChar="*" MaxLength="20"/>
                </StackPanel>
                
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,22,0,0">

                    <Button Content="Отмена"
                            Width="110"
                            Margin="0,0,10,0"
                            Background="#E5E7EB"
                            Foreground="#374151"
                            Command="{Binding CancelCommand}"/>

                    <Button Content="Сохранить"
                            Width="120"
                            Background="#10B981"
                            Foreground="White"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
