<Window x:Class="WarehouseInventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarehouseInventory"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="900"
        MaxHeight="800" MaxWidth="1300"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1">
        
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1ABC9C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#16A085"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#E8F0F2"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="VerticalGridLinesBrush" Value="#BDC3C7"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <TextBlock Text="Склад &amp; Инвентарь"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="10,20,10,30"
                           HorizontalAlignment="Center"/>
                <StackPanel>
                    <Button Content="🏠 Дашборд" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📦 Товары" Command="{Binding NavigateCommand}" CommandParameter="Products" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📋 Движения" Command="{Binding NavigateCommand}" CommandParameter="StockMovements" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📊 Диаграммы" Command="{Binding NavigateCommand}" CommandParameter="Charts" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="👥 Поставщики" Command="{Binding NavigateCommand}" CommandParameter="Suppliers" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="👤 Клиенты" Command="{Binding NavigateCommand}" CommandParameter="Customers" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📈 Отчёты" Command="{Binding NavigateCommand}" CommandParameter="Reports" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <Separator Margin="10,20,10,10" Background="#34495E"/>
                <TextBlock Text="{Binding CurrentEmployeeName}" Foreground="White" Margin="10,10"/>
                <Button Content="🚪 Выход" Command="{Binding LogoutCommand}" Background="#E74C3C" Foreground="White" Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>
        </Border>
        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border Background="#34495E" Grid.Row="0">
                <Grid>
                    <TextBlock Text="Справочник товаров"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="White" Margin="20,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/> 
                </Grid.RowDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                    <TextBox Width="250" Height="30" Margin="0,0,10,0" FontSize="14"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <Button Content="Добавить" Width="100" Height="30" Background="#27AE60" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Изменить" Width="100" Height="30" Background="#F39C12" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Удалить" Width="100" Height="30" Background="#E74C3C" Foreground="White"/>
                </StackPanel>
                
                <DataGrid Grid.Row="1" ItemsSource="{Binding Products}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="180"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="130"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>
