<Window x:Class="WarehouseInventory.Windows.SuppliersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WarehouseInventory.Windows"
        mc:Ignorable="d"
        Title="SuppliersWindow" Height="450" Width="1100">
    <Window.Resources>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          BlurRadius="20"
                          ShadowDepth="4"
                          Opacity="0.09"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,0,0,25">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0">

                <Button x:Name="MenuButton"
                        Content="☰"
                        Width="42"
                        Height="42"
                        FontSize="18"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        Command="{Binding ToggleMenuCommand}"/>

                <Popup IsOpen="{Binding IsMenuOpen}"
                       PlacementTarget="{Binding ElementName=MenuButton}"
                       Placement="Bottom"
                       StaysOpen="False">

                    <Border Background="White"
                            Width="220"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Padding="8"
                            Effect="{StaticResource CardShadow}">

                        <StackPanel>
                            <TextBlock Text="📂 Навигация"
                                       FontWeight="SemiBold"
                                       Margin="8,5,8,10"/>

                            <Separator/>

                            <Button Content="🏠 Дашборд" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Command="{Binding NavigateDashboardCommand}"/>
                            <Button Content="📦 Товары" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Command="{Binding NavigateProductsCommand}"/>
                            <Button Content="👤 Клиенты" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Command="{Binding NavigateCustomersCommand}"/>
                            <Button Content="🏭 Поставщики" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Command="{Binding NavigateSuppliersCommand}"/>
                            <Button Content="🧾 Накладные" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Command="{Binding NavigateInvoicesCommand}"/>

                            <Separator/>

                            <Button Content="🚪 Выход"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Foreground="#EF4444"
                                    Command="{Binding LogoutCommand}"/>
                        </StackPanel>

                    </Border>
                </Popup>

            </Grid>
            
            <TextBlock Grid.Column="1"
                       Text="🏭 Поставщики"
                       FontSize="27"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                
                <Border Width="320"
                        Height="44"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Margin="0,0,18,0">

                    <Grid>
                        <TextBlock Text="🔍"
                                   FontSize="19"
                                   Foreground="#9CA3AF"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>

                        <TextBox Margin="46,0,48,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 FontSize="15"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Поиск по названию, телефону..." />

                        <Button Content="✕"
                                Width="30"
                                Height="30"
                                HorizontalAlignment="Right"
                                Margin="0,0,8,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="#6B7280"
                                Command="{Binding ClearSearchCommand}"/>
                    </Grid>
                </Border>
                
                <Button Content="➕ Добавить"
                        Width="140"
                        Height="44"
                        Background="#10B981"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        Command="{Binding AddSupplierCommand}"/>

                <Button Content="✏️ Изменить"
                        Width="140"
                        Height="44"
                        Background="#F59E0B"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        Command="{Binding EditSupplierCommand}"/>

                <Button Content="🗑 Удалить"
                        Width="120"
                        Height="44"
                        Background="#EF4444"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Command="{Binding DeleteSupplierCommand}"/>

            </StackPanel>

        </Grid>
        
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="12"
                Effect="{StaticResource CardShadow}">

            <DataGrid ItemsSource="{Binding Suppliers}"
                      SelectedItem="{Binding SelectedSupplier}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="48"
                      GridLinesVisibility="None"
                      AlternatingRowBackground="#F9FAFB">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        MinWidth="240"/>

                    <DataGridTextColumn Header="Телефон"
                                        Binding="{Binding Phone}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Email"
                                        Binding="{Binding Email}"
                                        Width="260"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
