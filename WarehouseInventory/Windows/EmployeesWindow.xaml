<Window x:Class="WarehouseInventory.Windows.EmployeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WarehouseInventory.Windows"
        mc:Ignorable="d"
        Title="DashBoardWindow" Height="450" Width="980">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0">
                <Button Content="☰"
                        Width="40"
                        Height="40"
                        FontSize="18"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        VerticalAlignment="Center"
                        Command="{Binding ToggleMenuCommand}"/>
                
                <Popup IsOpen="{Binding IsMenuOpen}"
                       Placement="Bottom"
                       StaysOpen="False">

                    <Border Background="White"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Padding="10"
                            Width="180"
                            Margin="0,10,0,0">

                        <StackPanel>

                            <Button Content="📦 Товары"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding NavigateProductsCommand}"/>
                            
                            <Button Content="🏭 Поставщики"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding NavigateSuppliersCommand}"/>
                            
                            <Button Content="📊 Движения товаров"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding NavigateMovementsCommand}"/>
                            
                            <Button Content="📈 Отчёты"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding NavigateReportsCommand}"/>

                            <Button Content="🧾 Накладные"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding NavigateInvoicesCommand}"/>
                            
                            <Separator/>

                            <Button Content="🚪 Выход"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10"
                                    Foreground="#EF4444"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding LogoutCommand}"/>
                        </StackPanel>

                    </Border>
                </Popup>
            </Grid>
            
            <TextBlock Grid.Column="1"
                       Text="Сотрудники"
                       FontSize="27"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
            
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                
                <Border Width="290"
                        Height="44"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Margin="0,0,18,0">

                    <Grid>
                        <TextBlock Text="🔍"
                                   FontSize="19"
                                   Foreground="#9CA3AF"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>

                        <TextBox Margin="46,0,48,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 FontSize="15"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="✕"
                                Width="30"
                                Height="30"
                                HorizontalAlignment="Right"
                                Margin="0,0,8,0"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderBrush="Transparent"
                                Command="{Binding ClearSearchCommand}"/>
                    </Grid>
                </Border>
                
                <Button Content="😀 Добавить"
                        Width="140"
                        Height="44"
                        Background="#10B981"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        Command="{Binding AddCustomerCommand}"/>

                <Button Content="✏️ Изменить"
                        Width="120"
                        Height="44"
                        Background="#F59E0B"
                        Foreground="White"
                        Margin="0,0,10,0"
                        Command="{Binding EditCustomerCommand}"/>

                <Button Content="☠︎ Удалить"
                        Width="110"
                        Height="44"
                        Background="#EF4444"
                        Foreground="White"
                        Command="{Binding DeleteCustomerCommand}"/>

            </StackPanel>
        </Grid>

        <!-- TABLE -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="12"
                Effect="{StaticResource CardShadow}">

            <DataGrid ItemsSource="{Binding Customers}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      RowHeight="54"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      AlternatingRowBackground="#F9FAFB">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя / Организация"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        MinWidth="240"/>

                    <DataGridTextColumn Header="Телефон"
                                        Binding="{Binding Phone}"
                                        Width="170"/>

                    <DataGridTextColumn Header="Email"
                                        Binding="{Binding Email}"
                                        Width="260"/>

                    <DataGridTextColumn Header="Адрес"
                                        Binding="{Binding Address}"
                                        Width="*"/>
                </DataGrid.Columns>

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,14"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.Resources>

            </DataGrid>
        </Border>

    </Grid>

</Window>
